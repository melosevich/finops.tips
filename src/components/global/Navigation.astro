---
// Assets
import Logo from "@/components/assets/Logo.astro";
// fundations
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import JobSearch from "@/components/global/Search.astro";
import MobileNav from "@/components/global/MobileNav.astro";
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];
---
<section>
  <Wrapper variant="standard">
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 py-2">
      <a href="/" class="flex items-center gap-2">
        <Logo class="text-primary font-medium lowercase" />
      </a>
      <div class="hidden items-center gap-4 text-primary lg:flex justify-center lg:col-span-3">
        {navLinks.map((link) => (
          <a href={link.href} class="hover:text-primary text-sm duration-300">
            {link.label}
          </a>
        ))}
      </div>
      <div class="items-center gap-2 flex ml-auto">
        <JobSearch />
      <button
        id="navToggle"
        class="hover:text-primary/40 duration-300 text-primary text-sm lg:hidden"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        Menu
      </button>
      </div>
    </div>
  </Wrapper>
</section>
<MobileNav links={navLinks} />
