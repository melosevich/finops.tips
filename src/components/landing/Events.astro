---
import Text from "@/components/fundations/elements/Text.astro";
import EventEntry from "@/components/events/EventEntry.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");

// Events policy:
// - only upcoming (>= today)
// - only within the next ~3 months (90 days)
// - order: sooner → later
// - max 10
const today = new Date();
const startOfToday = new Date(today.getFullYear(), today.getMonth(), today.getDate());
const maxDate = new Date(startOfToday);
maxDate.setDate(maxDate.getDate() + 90);

const events = allPosts
  .filter((p) => p.data.tags?.includes("events"))
  .filter((p) => {
    const d = new Date(p.data.pubDate);
    return d >= startOfToday && d <= maxDate;
  })
  .sort((a, b) => new Date(a.data.pubDate).getTime() - new Date(b.data.pubDate).getTime())
  .slice(0, 10);
---

<div>
  <Text tag="h2" variant="textBase" class="font-medium text-primary">Events</Text>
  <div class="flex flex-col mt-1 divide-y divide-primary/10 border-y border-primary/10">
    {events.map((post) => <EventEntry post={post} />)}
  </div>
</div>
