---
// Minimal Mailchimp signup form (no external CSS/JS).
// Posts to Mailchimp in a hidden iframe so the user stays on the same page.
// We can’t reliably detect success (cross-origin), so we show a friendly message
// telling them to check their inbox.

const {
  action =
    "https://tips.us9.list-manage.com/subscribe/post?u=8845686e07410de30f3eb851b&id=46a7f39ff4&f_id=0070c2e1f0",
  buttonText = "Get daily tips",
  placeholder = "you@company.com",
} = Astro.props;

const honeypotName = "b_8845686e07410de30f3eb851b_46a7f39ff4";
const formId = "mc-signup-form";
const iframeName = "mc-hidden-iframe";
---

<div class="mt-6 mx-auto w-full max-w-2xl text-center">
  <form
    id={formId}
    class="mx-auto flex w-full flex-col gap-3 sm:flex-row sm:items-center sm:justify-center"
    action={action}
    method="post"
    target={iframeName}
    novalidate
  >
    <label class="sr-only" for="mc-email">Email</label>
    <input
      id="mc-email"
      name="EMAIL"
      type="email"
      required
      inputmode="email"
      autocomplete="email"
      placeholder={placeholder}
      class="w-full rounded-lg border border-primary/20 bg-background px-4 py-3 text-sm text-primary placeholder:text-primary/40 focus:outline-none focus:ring-2 focus:ring-black/40 sm:max-w-md"
    />

    {/* Bot trap (Mailchimp recommended). Keep it off-screen. */}
    <div aria-hidden="true" class="absolute left-[-5000px]">
      <input type="text" name={honeypotName} tabindex="-1" value="" />
    </div>

    <button
      type="submit"
      class="inline-flex w-full items-center justify-center rounded-lg bg-black px-6 py-3 text-sm font-medium text-white hover:bg-black/90 transition sm:w-auto whitespace-nowrap"
    >
      {buttonText}
    </button>
  </form>

  <p id="mc-privacy" class="mt-3 text-xs text-primary/60">
    To learn how we process your data, visit our
    <a class="underline underline-offset-4 hover:text-primary" href="/legal/privacy/">Privacy Notice</a>.
    You can unsubscribe at any time.
  </p>

  <p
    id="mc-thanks"
    class="mt-3 hidden text-xs text-primary/80"
  >
    Thanks — check your inbox to confirm your subscription.
  </p>

  <iframe name={iframeName} class="hidden" title="Mailchimp hidden iframe"></iframe>
</div>

<script>
  (function () {
    const form = document.getElementById("mc-signup-form");
    const thanks = document.getElementById("mc-thanks");
    const privacy = document.getElementById("mc-privacy");
    if (!form || !thanks || !privacy) return;

    form.addEventListener("submit", () => {
      // Keep user on the same page and show a friendly message.
      privacy.classList.add("hidden");
      thanks.classList.remove("hidden");
    });
  })();
</script>
