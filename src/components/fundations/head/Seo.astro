---
import { AstroSeo } from "@astrolib/seo";

const title = Astro.props.title ?? "FinOps Tips";
const description =
  Astro.props.description ??
  "Daily, bite-sized FinOps wisdom: operations, services, and metrics — with practical examples.";

// Astro.site comes from astro.config.mjs (we set it to https://finops.tips)
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<AstroSeo
  title={title}
  description={description}
  canonical={canonical}
  openGraph={{
    url: canonical,
    title,
    description,
    site_name: "FinOps Tips",
    type: "website",
    locale: "en_US",
  }}
/>

<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />
